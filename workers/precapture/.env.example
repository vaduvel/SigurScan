# Supabase is optional. If these two are missing, worker writes local manifest + screenshots.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

STORAGE_BUCKET=previews
CACHE_TABLE=fast_preview_cache
CACHE_TTL_DAYS=7
MAX_REDIRECT_HOPS=10
NAV_TIMEOUT_SECONDS=20
MAX_URLS=50
CONCURRENCY=1
MAX_SCREENSHOT_HEIGHT=5000
CHROMIUM_SANDBOX=true
USER_AGENT=SigurScanPreviewBot/1.0 (+https://sigurscan.ro/bot)
ALIAS_TABLE=fast_preview_alias_cache
