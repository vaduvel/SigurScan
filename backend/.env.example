# Supabase configuration
SUPABASE_URL=https://<your-project-ref>.supabase.co
# Server-only. Never ship this key in Android/iOS/React Native apps.
SUPABASE_SERVICE_ROLE_KEY=<your_service_role_key>

# Backend config
MAX_TEXT_CHARS=12000
MAX_URLS_PER_SCAN=15
RISK_THRESHOLD=50
SIGURSCAN_SAFE_MODE=false

# API security
# Public mobile clients cannot safely hold a shared secret. Keep REQUIRE_API_KEY=false
# for the mobile scan API unless you add app attestation or a backend-issued token.
REQUIRE_API_KEY=false
SIGURSCAN_API_KEYS=
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=60
ALLOWED_ORIGINS=https://sigurscan.ro,https://www.sigurscan.ro,https://sigurscan-backend.vercel.app
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# External services (optional - leave empty to disable)
GEMINI_API_KEY=
MISTRAL_API_KEY=
GOOGLE_CLOUD_VISION_API_KEY=
GOOGLE_WEB_RISK_API_KEY=
ENABLE_PHISHING_DATABASE=true
PHISHING_DATABASE_DOMAINS_URL=https://raw.githubusercontent.com/Phishing-Database/Phishing.Database/master/phishing-domains-ACTIVE.txt
PHISHING_DATABASE_LINKS_URL=https://phish.co.za/latest/phishing-links-ACTIVE.txt
PHISHING_DATABASE_FEED_TTL_SECONDS=3600
# Optional. URLhaus requires an abuse.ch Auth-Key; leave empty to skip cleanly.
URLHAUS_AUTH_KEY=
SIGURSCAN_URLSCAN_API_KEY=
AI_EXPLAINER_PROVIDER=auto
MISTRAL_MODEL=mistral-small-latest
ENABLE_MISTRAL_SHADOW_ADJUDICATION=false
MISTRAL_ADJUDICATOR_MODEL=mistral-small-2503
MISTRAL_ADJUDICATOR_TIMEOUT_SECONDS=2.5
URLSCAN_VISIBILITY_DEFAULT=private
URLSCAN_TIMEOUT_SECONDS=8.0
URLSCAN_COUNTRY_DEFAULT=ro
URLSCAN_CUSTOM_AGENT=
GOOGLE_WEB_RISK_TIMEOUT_SECONDS=3.0
MAX_WEB_RISK_URLS=20

# Scan latency policy
FAST_REPUTATION_MODE=true
FAST_REPUTATION_INCLUDE_URLHAUS=false
URL_REPUTATION_CACHE_MAX_ITEMS=1000
ENABLE_DEEP_REPUTATION_FALLBACK=true
ENABLE_CLOUD_AI_EXPLANATION=true
AI_EXPLANATION_TIMEOUT_SECONDS=2.5
ENABLE_OFFER_CLAIM_WEB_CHECK=true
AI_OFFER_CLAIM_TIMEOUT_SECONDS=5.0
OFFER_CLAIM_HTTP_TIMEOUT_SECONDS=3.0
OFFER_CLAIM_GEMINI_MODEL=gemini-2.5-flash
OFFER_CLAIM_GEMINI_TIMEOUT_SECONDS=4.0
OFFER_CLAIM_GEMINI_MAX_OUTPUT_TOKENS=512
OFFER_CLAIM_GEMINI_THINKING_BUDGET=0
OFFER_CLAIM_GEMINI_THINKING_LEVEL=minimal
